{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeeble",
  "version": "0.1.11",
  "identifier": "xyz.zeeble.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.zeeble.xyz/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDMEM5RkM0OUFBNUVDMApSV1RBWHFwSi9NbkFBb0s0T0RLZjJrYWNpd29EOGtnK3dReENMcnlxVE9xTllTdlNEcEZwSzd6ZAo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
