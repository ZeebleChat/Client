{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/schemas/capability.schema.json",
  "identifier": "default",
  "description": "Default capabilities for Zeeble",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging"
  ]
}
